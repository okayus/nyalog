{
  "name": "@nyalog/api",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply nyalog-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply nyalog-db --remote"
  },
  "dependencies": {
    "hono": "^4",
    "drizzle-orm": "^0.40",
    "neverthrow": "^8",
    "zod": "^3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4",
    "drizzle-kit": "^0.30",
    "typescript": "^5",
    "wrangler": "^4"
  }
}
