{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "nyalog",
  "compatibility_date": "2025-03-28",
  "main": "./worker/index.ts",
  "assets": {
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": true,
  },
  "vars": {
    // RP_ID is the workers.dev hostname without scheme/port.
    // Passkeys are bound to this value — changing it invalidates all registrations.
    "RP_ID": "nyalog.toshiaki-mukai-9981.workers.dev",
    "ORIGIN": "https://nyalog.toshiaki-mukai-9981.workers.dev",
    // 血液検査画像の解析エンジン選択。worker/lib/analyzer/factory.ts の switch case と対応。
    // 将来 Claude Vision 等を増やす時はここを書き換える。
    "ANALYZER_MODEL": "workers-ai-gemma",
  },
  // Workers AI には local simulation が無く、vp dev は起動時に remote proxy session を立てる。
  // CI で起動するには .github/workflows/check.yml の e2e step に CLOUDFLARE_API_TOKEN +
  // CLOUDFLARE_ACCOUNT_ID env を渡す必要がある (本 PR の CI workflow 変更で対応済み)。
  "ai": {
    "binding": "AI",
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "nyalog-db",
      "database_id": "82db6367-0a73-46d3-baf3-c665adf1e10b",
      "migrations_dir": "drizzle",
    },
  ],
  "r2_buckets": [
    {
      "binding": "MEDICAL_BUCKET",
      "bucket_name": "nyalog-medical",
    },
  ],
}
