    "zod": "^3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1",
    "@cloudflare/workers-types": "^4",
    "@playwright/test": "^1.59.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.30",
    "typescript": "^5",
    "vite-plus": "^0.1",
